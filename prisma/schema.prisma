generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String         @id @default(cuid())
  role                String         @default("PATIENT") // PATIENT, SUPER_ADMIN, ADMIN, SUPPORT_AGENT
  name                String
  email               String         @unique
  password            String
  phone               String         // WhatsApp number
  country             String         @default("Unknown")
  timezone            String         @default("UTC")
  
  // Admin & Security Fields
  whatsappVerified    Boolean        @default(false)
  twoFactorSecret     String?
  twoFactorEnabled    Boolean        @default(false)
  failedLoginAttempts Int            @default(0)
  lockedUntil         DateTime?
  lastLogin           DateTime?

  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  subscription        Subscription?
  medicines           Medicine[]
  familyMembers       FamilyMember[]
  messageLogs         MessageLog[]
  
  // Admin relations
  adminNotesGiven     AdminNote[]    @relation("NoteAuthor")
  adminNotesReceived  AdminNote[]    @relation("NoteTarget")
  supportTickets      SupportTicket[] @relation("TicketCreator")
  assignedTickets     SupportTicket[] @relation("TicketAssignee")
  ticketMessages      SupportTicketMessage[]
  auditLogs           AuditLog[]

  // Referral Program
  referralCode          String?        @unique
  referralsMonthlyCount Int            @default(0)
  referralsBiannualCount Int           @default(0)
  referralsAnnualCount  Int            @default(0)

  // Affiliate Relations
  referredByCode      String?
  affiliateProfile    AffiliateProfile?
}

model Subscription {
  id                   String    @id @default(cuid())
  userId               String    @unique
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  planType             String    // BASIC, STANDARD, FAMILY
  status               String    @default("INACTIVE") // ACTIVE, INACTIVE, EXPIRED, CANCELLED
  paypalSubscriptionId String?   @unique
  startDate            DateTime?
  expiryDate           DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
}

model PaymentTransaction {
  id              String   @id @default(cuid())
  userId          String
  planType        String
  billingCycle    String   // MONTHLY, ANNUAL
  amount          Float
  currency        String   @default("USD")
  method          String   // e.g., "Visa 4242"
  gatewayId       String?  @unique
  status          String   // SUCCEEDED, FAILED, REFUNDED, DISPUTED
  failureReason   String?
  receiptUrl      String?
  createdAt       DateTime @default(now())
}

model Medicine {
  id             String         @id @default(cuid())
  userId         String
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  familyMemberId String?
  familyMember   FamilyMember?  @relation(fields: [familyMemberId], references: [id], onDelete: Cascade)
  name           String
  dosage         String?
  daysActive     String         @default("EVERY_DAY") // EVERY_DAY, WEEKDAYS, WEEKENDS, CUSTOM
  note           String?
  status         String         @default("ACTIVE") // ACTIVE, PAUSED
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  reminders      ReminderTime[]
  messageLogs    MessageLog[]
}

model ReminderTime {
  id          String   @id @default(cuid())
  medicineId  String
  medicine    Medicine @relation(fields: [medicineId], references: [id], onDelete: Cascade)
  time        String   // Format: HH:mm (e.g. 09:00, 14:30)
}

model FamilyMember {
  id              String   @id @default(cuid())
  accountHolderId String
  accountHolder   User     @relation(fields: [accountHolderId], references: [id], onDelete: Cascade)
  name            String
  phone           String
  relationship    String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  medicines       Medicine[]
}

model MessageLog {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  medicineId  String?
  medicine    Medicine? @relation(fields: [medicineId], references: [id], onDelete: SetNull)
  type        String    // REMINDER, WELCOME, EXPIRY_WARNING, EXPIRY, POST_EXPIRY, NUMBER_VERIFICATION
  channel     String    // WHATSAPP, SMS
  status      String    // DELIVERED, FAILED, PENDING
  errorReason String?
  scheduledFor DateTime?
  sentAt      DateTime  @default(now())
}

model SupportTicket {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation("TicketCreator", fields: [userId], references: [id], onDelete: Cascade)
  assigneeId  String?
  assignee    User?    @relation("TicketAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  subject     String
  status      String   @default("OPEN") // OPEN, IN_PROGRESS, RESOLVED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  messages    SupportTicketMessage[]
}

model SupportTicketMessage {
  id          String        @id @default(cuid())
  ticketId    String
  ticket      SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  senderId    String
  sender      User          @relation(fields: [senderId], references: [id], onDelete: Cascade)
  message     String
  isInternal  Boolean       @default(false)
  createdAt   DateTime      @default(now())
}

model AdminNote {
  id          String   @id @default(cuid())
  patientId   String
  patient     User     @relation("NoteTarget", fields: [patientId], references: [id], onDelete: Cascade)
  adminId     String
  admin       User     @relation("NoteAuthor", fields: [adminId], references: [id], onDelete: Cascade)
  note        String
  createdAt   DateTime @default(now())
}

model AuditLog {
  id          String   @id @default(cuid())
  adminId     String?
  admin       User?    @relation(fields: [adminId], references: [id], onDelete: SetNull)
  ipAddress   String?
  device      String?
  action      String   // e.g. "ACTIVATED_SUBSCRIPTION", "DELETED_USER", "LOGIN_FAILED"
  targetId    String?  // The ID of the record that was changed
  details     String?  // JSON string of changes
  createdAt   DateTime @default(now())
}

model SystemSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String   // JSON string to support complex structures or simple text
  updatedAt   DateTime @updatedAt
}

model MessageTemplate {
  id          String   @id @default(cuid())
  name        String   @unique
  category    String   // REMINDER, WELCOME, EXPIRY
  content     String
  metaStatus  String   @default("PENDING") // APPROVED, PENDING, REJECTED
  lastEditedBy String
  updatedAt   DateTime @updatedAt
}

model BroadcastMessage {
  id            String   @id @default(cuid())
  audience      String   // ALL_ACTIVE, SPECIFIC_PLAN, etc.
  content       String
  sentCount     Int      @default(0)
  failureCount  Int      @default(0)
  scheduledFor  DateTime?
  sentAt        DateTime?
  createdAt     DateTime @default(now())
}

model AffiliateProfile {
  id                    String   @id @default(cuid())
  userId                String   @unique
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  refCode               String   @unique
  status                String   @default("PENDING") // PENDING, ACTIVE, SUSPENDED
  promotionMethod       String
  payoutMethod          String   // PAYPAL, BANK
  payoutDetails         String   // Email or bank details
  commissionType        String   @default("RECURRING") // RECURRING, ONE_TIME
  customCommissionRate  Float?   // Override default rate
  totalEarnings         Float    @default(0)
  pendingEarnings       Float    @default(0)
  availableEarnings     Float    @default(0)
  clicks                Int      @default(0)
  conversions           Int      @default(0)
  joinedAt              DateTime @default(now())
  updatedAt             DateTime @updatedAt

  affiliateClicks       AffiliateClick[]
  affiliateConversions  AffiliateConversion[]
  affiliatePayouts      AffiliatePayout[]
}

model AffiliateClick {
  id          String   @id @default(cuid())
  affiliateId String
  affiliate   AffiliateProfile @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  ipAddress   String?
  userAgent   String?
  clickedAt   DateTime @default(now())
}

model AffiliateConversion {
  id               String   @id @default(cuid())
  affiliateId      String
  affiliate        AffiliateProfile @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  referredUserId   String
  planType         String
  paymentAmount    Float
  commissionAmount Float
  status           String   @default("PENDING") // PENDING, CLEARED, PAID, CANCELLED
  paymentId        String   @unique
  createdAt        DateTime @default(now())
  clearedAt        DateTime?
}

model AffiliatePayout {
  id          String   @id @default(cuid())
  affiliateId String
  affiliate   AffiliateProfile @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  amount      Float
  status      String   @default("PENDING") // PENDING, PAID
  method      String
  details     String
  adminNote   String?
  createdAt   DateTime @default(now())
  paidAt      DateTime?
}

