generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                       String                 @id @default(cuid())
  role                     String                 @default("PATIENT")
  name                     String
  email                    String                 @unique
  password                 String
  phone                    String
  country                  String                 @default("Unknown")
  timezone                 String                 @default("UTC")
  createdAt                DateTime               @default(now())
  updatedAt                DateTime               @updatedAt
  failedLoginAttempts      Int                    @default(0)
  lastLogin                DateTime?
  lockedUntil              DateTime?
  twoFactorEnabled         Boolean                @default(false)
  twoFactorSecret          String?
  whatsappVerified         Boolean                @default(false)
  referredByCode           String?
  referralCode             String?                @unique
  freeMonthsApplied        Int                    @default(0)
  freeMonthsEarned         Int                    @default(0)
  totalSuccessfulReferrals Int                    @default(0)
  adminNotesGiven          AdminNote[]            @relation("NoteAuthor")
  adminNotesReceived       AdminNote[]            @relation("NoteTarget")
  affiliateProfile         AffiliateProfile?
  auditLogs                AuditLog[]
  familyMembers            FamilyMember[]
  medicines                Medicine[]
  messageLogs              MessageLog[]
  referralReceived         Referral?              @relation("ReferredBy")
  referralsGiven           Referral[]             @relation("ReferredUsers")
  subscription             Subscription?
  assignedTickets          SupportTicket[]        @relation("TicketAssignee")
  supportTickets           SupportTicket[]        @relation("TicketCreator")
  ticketMessages           SupportTicketMessage[]
}

model Subscription {
  id                   String    @id @default(cuid())
  userId               String    @unique
  planType             String
  status               String    @default("INACTIVE")
  paypalSubscriptionId String?   @unique
  startDate            DateTime?
  expiryDate           DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PaymentTransaction {
  id            String   @id @default(cuid())
  userId        String
  planType      String
  billingCycle  String
  amount        Float
  currency      String   @default("USD")
  method        String
  gatewayId     String?  @unique
  status        String
  failureReason String?
  receiptUrl    String?
  createdAt     DateTime @default(now())
}

model Medicine {
  id             String         @id @default(cuid())
  userId         String
  name           String
  dosage         String?
  daysActive     String         @default("EVERY_DAY")
  note           String?
  status         String         @default("ACTIVE")
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  familyMemberId String?
  familyMember   FamilyMember?  @relation(fields: [familyMemberId], references: [id], onDelete: Cascade)
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  messageLogs    MessageLog[]
  reminders      ReminderTime[]
}

model ReminderTime {
  id         String   @id @default(cuid())
  medicineId String
  time       String
  medicine   Medicine @relation(fields: [medicineId], references: [id], onDelete: Cascade)
}

model FamilyMember {
  id              String     @id @default(cuid())
  accountHolderId String
  name            String
  phone           String
  relationship    String
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  accountHolder   User       @relation(fields: [accountHolderId], references: [id], onDelete: Cascade)
  medicines       Medicine[]
}

model MessageLog {
  id           String    @id @default(cuid())
  userId       String
  type         String
  channel      String
  status       String
  errorReason  String?
  scheduledFor DateTime?
  sentAt       DateTime  @default(now())
  medicineId   String?
  medicine     Medicine? @relation(fields: [medicineId], references: [id])
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SupportTicket {
  id         String                 @id @default(cuid())
  userId     String
  assigneeId String?
  subject    String
  status     String                 @default("OPEN")
  createdAt  DateTime               @default(now())
  updatedAt  DateTime               @updatedAt
  assignee   User?                  @relation("TicketAssignee", fields: [assigneeId], references: [id])
  user       User                   @relation("TicketCreator", fields: [userId], references: [id], onDelete: Cascade)
  messages   SupportTicketMessage[]
}

model SupportTicketMessage {
  id         String        @id @default(cuid())
  ticketId   String
  senderId   String
  message    String
  isInternal Boolean       @default(false)
  createdAt  DateTime      @default(now())
  sender     User          @relation(fields: [senderId], references: [id], onDelete: Cascade)
  ticket     SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
}

model AdminNote {
  id        String   @id @default(cuid())
  patientId String
  adminId   String
  note      String
  createdAt DateTime @default(now())
  admin     User     @relation("NoteAuthor", fields: [adminId], references: [id], onDelete: Cascade)
  patient   User     @relation("NoteTarget", fields: [patientId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        String   @id @default(cuid())
  adminId   String?
  ipAddress String?
  device    String?
  action    String
  targetId  String?
  details   String?
  createdAt DateTime @default(now())
  admin     User?    @relation(fields: [adminId], references: [id])
}

model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model MessageTemplate {
  id           String   @id @default(cuid())
  name         String   @unique
  category     String
  content      String
  metaStatus   String   @default("PENDING")
  lastEditedBy String
  updatedAt    DateTime @updatedAt
}

model BroadcastMessage {
  id           String    @id @default(cuid())
  audience     String
  content      String
  sentCount    Int       @default(0)
  failureCount Int       @default(0)
  scheduledFor DateTime?
  sentAt       DateTime?
  createdAt    DateTime  @default(now())
}

model AffiliateProfile {
  id                   String                @id @default(cuid())
  userId               String                @unique
  refCode              String                @unique
  status               String                @default("PENDING")
  promotionMethod      String
  payoutMethod         String
  payoutDetails        String
  commissionType       String                @default("RECURRING")
  customCommissionRate Float?
  totalEarnings        Float                 @default(0)
  pendingEarnings      Float                 @default(0)
  availableEarnings    Float                 @default(0)
  clicks               Int                   @default(0)
  conversions          Int                   @default(0)
  joinedAt             DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  affiliateClicks      AffiliateClick[]
  affiliateConversions AffiliateConversion[]
  affiliatePayouts     AffiliatePayout[]
  user                 User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AffiliateClick {
  id          String           @id @default(cuid())
  affiliateId String
  ipAddress   String?
  userAgent   String?
  clickedAt   DateTime         @default(now())
  affiliate   AffiliateProfile @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
}

model AffiliateConversion {
  id               String           @id @default(cuid())
  affiliateId      String
  referredUserId   String
  planType         String
  paymentAmount    Float
  commissionAmount Float
  status           String           @default("PENDING")
  paymentId        String           @unique
  createdAt        DateTime         @default(now())
  clearedAt        DateTime?
  affiliate        AffiliateProfile @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
}

model AffiliatePayout {
  id          String           @id @default(cuid())
  affiliateId String
  amount      Float
  status      String           @default("PENDING")
  method      String
  details     String
  adminNote   String?
  createdAt   DateTime         @default(now())
  paidAt      DateTime?
  affiliate   AffiliateProfile @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
}

model Referral {
  id                 String   @id @default(cuid())
  referrerId         String
  referredUserId     String   @unique
  status             String   @default("PENDING")
  planType           String?
  billingCycle       String?
  rewardContribution Float    @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  referredUser       User     @relation("ReferredBy", fields: [referredUserId], references: [id], onDelete: Cascade)
  referrer           User     @relation("ReferredUsers", fields: [referrerId], references: [id], onDelete: Cascade)
}
